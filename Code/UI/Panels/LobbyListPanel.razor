@using Sandbox
@using Sandbox.Diagnostics
@using Sandbox.UI
@using Sandbox.Network
@using Sandbox.UI.Navigation
@using Sandbox
@using Sandbox.UI.NavigationHosts

@inherits Panel
@implements INavigatorPage
@namespace Sandbox.UI.Panels

<root class="hc1">
    <PagePanel>
        <Header>
            Server Browser
        </Header>

        <Body>
            <div class="layout grow padding-insane">
                <ServerBrowserPanel CurrentLobby:bind=@Lobby  @ref="Browser" />
            </div>
        </Body>

        <Footer>
            <div class="button standard" onclick=@(() => Refresh())>refresh</div>
            <a class="button standard" href="/new">Create Game</a>
            <div class="button standard @(Lobby.HasValue ? "" : "no-anim disabled")" onclick=@(() => TryJoin())>
                <label>
                    Join
                </label>
                @if ( Lobby.HasValue )
                {
                    <label class="slight">Session</label>
                }
            </div>
        </Footer>
    </PagePanel>
</root>

@code
{
    public ServerBrowserPanel Browser { get; set; }

    public Lobby? Lobby { get; set; }

    private void Refresh()
    {
        Browser.Refresh();
    }

    private void Create()
    {
        this.Navigate( "/new" );
    }

    private void TryJoin()
    {
        if ( !Lobby?.HasData ?? false )
        {
            DialogModalPanel.Show("This server is outdated and you may experience issues - we'd advise making your own lobby instead!", "OK", "Join anyway", null, () =>
            {
                Join();
            });
        }
        else
        {
            Join();
        }
    }

    private async void Join()
    {
        if ( !Lobby.HasValue ) return;

        var lobby = Lobby.Value;
        if ( lobby.IsFull ) return;

        if ( await Networking.TryConnectSteamId( lobby.LobbyId ) )
		{
			Log.Info( "joined lobby!" );
		}
    }

    public void OnNavigationOpen()
    {
        if ( MainMenuNavigationHost.Instance.IsValid() )
        {
            MainMenuNavigationHost.Instance.SetBlur( true );
        }
    }
    
    public void OnNavigationClose() 
    {
        if ( MainMenuNavigationHost.Instance.IsValid() )
        {
            MainMenuNavigationHost.Instance.SetBlur( false );
        }
    }
}
