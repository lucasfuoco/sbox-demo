@namespace Sandbox.UI.Panels
@using Sandbox.Components
@using Sandbox.Components.PawnComponents
@using Sandbox.GameResources
@inherits Panel
@attribute [StyleSheet]

@if ( !Player.IsValid() ) return;

<root class="hud with-deadzone flex column">
    @if (false)
    {
        @foreach (var slotGroup in Inventory.Equipment.OrderBy(x => x.Resource.Slot).GroupBy(x => x.Resource.Slot))
        {
            <div class="layout group @GroupClasses( slotGroup.Key )">
                <div class="background" />

                <InputHintPanel Action="Slot@(SlotIndex(slotGroup.Key))" class="small" Size="@InputGlyphSize.Small" />

                @foreach (var equipment in slotGroup)
                {
                    <EquipmentRowPanel Equipment=@equipment/>
                }
            </div>
        }

    }

    @* Battlefield Style UI *@
    @if ( true )
    {
        @foreach ( var weapon in OtherWeapons )
        {
            <WeaponPanel Weapon=@weapon Class="other" />
        }

        <WeaponPanel Weapon=@Primary Class="primary" />
        
        <div class="row">
            <InputHintPanel Action=@Slot class="small" />
            <WeaponPanel Weapon=@Secondary />
        </div>
    }
</root>

@code
{
    public PlayerPawnComponent Player => ClientComponent.Viewer.PlayerPawn;
    public PlayerInventoryComponent Inventory => Player.Inventory;
    public EquipmentComponent CurrentEquipment => Player?.CurrentEquipment;

    EquipmentComponent Primary => Inventory.Equipment.FirstOrDefault(x => x.Resource.Slot == EquipmentSlot.Primary);
    EquipmentComponent Secondary => Inventory.Equipment.FirstOrDefault(x => x.Resource.Slot == EquipmentSlot.Secondary);

    public List<EquipmentComponent> OtherWeapons {
        get
        {
            if ( !Player.IsValid() ) return new List<EquipmentComponent>();
            return Inventory.Equipment
                .Where(x => x.Resource.Slot != EquipmentSlot.Primary && x.Resource.Slot != EquipmentSlot.Secondary && x.Resource.Slot != EquipmentSlot.Melee)
                .OrderBy(x => x.Resource.Slot)
                .ToList();
        }
    }

    public string Slot
    {
        get
        {
            if (Player.CurrentEquipment == Primary) return "Slot2";
            return "Slot1";
        }
    }

    public string GroupClasses( EquipmentSlot slot )
    {
        var wpn = CurrentEquipment;
        if (!wpn.IsValid()) return "";

        if (wpn.Resource.Slot == slot) return "active color-border-right";

        return "";
    }

    public int SlotIndex( EquipmentSlot slot )
    {
        return (int)slot;
    }

    public int GetSlot( EquipmentComponent equipment ) => Inventory.Equipment.ToList().IndexOf( equipment );

    protected override int BuildHash()
    {
        return !Player.IsValid() ? 0 : HashCode.Combine( Inventory.Equipment.Count(), CurrentEquipment );
    }
}
